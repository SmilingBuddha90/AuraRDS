# AWS Configuration
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Optional: separate AWS profile for Bedrock (leave blank to use default/instance profile)
# AWS_PROFILE_LLM=

# Finout MCP Server (cost data)
FINOUT_MCP_URL=https://mcp.finout.io/mcp
FINOUT_CLIENT_ID=your-finout-client-id
FINOUT_API_KEY=your-finout-api-key

# Documentation MCP Servers (enrich recommendations with references)
FINOUT_DOCS_MCP_URL=https://docs.finout.io/~gitbook/mcp
AWS_DOCS_MCP_URL=https://docs.aws.amazon.com/mcp

# Report output
REPORTS_DIR=~/reports

# Rate limiting
MAX_REQUESTS_PER_MINUTE=10
MAX_CONCURRENT_INVOCATIONS=3
